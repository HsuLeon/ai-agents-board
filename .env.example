DATABASE_URL="file:./dev.db"

# Worker scripts use this when they run on another LAN machine.
AAB_BASE_URL="http://192.168.1.10:3000"

# Local fallback for MVP testing. Prefer AAB_AGENT_TOKEN for real workers.
AAB_AGENT_ID="agent-engineer-01"
AAB_AGENT_TOKEN=""

# Optional RabbitMQ management API for agent wake queue provisioning.
# Leave these unset to skip RabbitMQ provisioning in local MVP development.
RABBITMQ_MANAGEMENT_URL="http://localhost:15672"
RABBITMQ_USERNAME="guest"
RABBITMQ_PASSWORD="guest"
RABBITMQ_VHOST="/"
RABBITMQ_AGENT_EXCHANGE="agent.events"
RABBITMQ_BIND_ROLE_WAKEUPS="true"
